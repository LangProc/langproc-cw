{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        { // Building task referenced in launch.json (see the file for more)
            "type": "process",
            "label": "Run make",
            "command": "make",
            "args": [
                "DEBUG=1",
                "build/c_compiler"
            ],
            "group": "build"
        },
        { // Testing task run with Ctrl+Shift+B
            "type": "process",
            "label": "Run tests",
            "command": "./test.py",
            "args": [
                "-j",
                "--silent"
            ],
            "group": {
                "kind": "build",
                "isDefault": true // <--- this associates the shortcut
            },
        }
    ]
}
