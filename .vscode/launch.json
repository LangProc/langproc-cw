{
    // This is the action launched when pressing F5, refers to task "Record failure" in tasks.json
    "version": "0.2.0",
    "configurations": [
        { // NOT WORKING! TODO WHEN MIDAS WILL BE WORKING
            "name": "Debug c_compiler",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/c_compiler",
            "preLaunchTask": "Record failure", // <--- HERE
            "stopAtEntry": true,
            "setupCommands": [
                {
                    "description": "Setup to resolve symbols",
                    "text": "set sysroot ${workspaceFolder}",
                    "ignoreFailures": false
                },
                {
                    "text": "set debuginfod enabled off",
                    "ignoreFailures": false
                },
                {
                    "text": "set auto-load safe-path ${workspaceFolder}",
                    "ignoreFailures": false
                },
                {
                    "description": "Enable GDB pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": false
                },
                {
                    "description": "Show Intel style disassembly in GDB",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": false
                }
            ],
            "ignoreStandardLibrary": true,
            "rrOptions": [
                "-n" // Cannot set kernel.perf_event_paranoid to 1 in a container
            ]
        }
    ]
}
